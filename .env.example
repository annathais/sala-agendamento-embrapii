# Porta do servidor (a maioria dos serviços de hospedagem define isso sozinho)
PORT=3000

# --- Configuração de SMTP para envio de email ---
# Exemplo com Gmail (veja README.md para como gerar a "senha de app"):
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=seuemail@gmail.com
SMTP_PASS=sua_senha_de_app_de_16_digitos
SMTP_FROM="Sala de Reunião <seuemail@gmail.com>"
