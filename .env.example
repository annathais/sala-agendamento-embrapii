# Porta do servidor (a maioria dos serviços de hospedagem define isso sozinho)
PORT=3000

# --- Configuração de SMTP para envio de email ---
# Exemplo com Gmail (veja README.md para como gerar a "senha de app"):
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=seuemail@gmail.com
SMTP_PASS=sua_senha_de_app_de_16_digitos
SMTP_FROM="Sala de Reunião <seuemail@gmail.com>"

# --- Integração com Google Sheets (opcional) ---
# Veja o README.md para o passo a passo completo.
GOOGLE_SHEETS_ID=id_da_sua_planilha
GOOGLE_SHEETS_TAB=Reservas

# Opção A (recomendada): coloque o arquivo baixado do Google como
# "google-service-account.json" na raiz do projeto — não precisa preencher nada aqui.
#
# Opção B (alternativa, só se não puder usar arquivo): descomente e cole o conteúdo
# em base64 do arquivo .json, em uma única linha, sem aspas.
# GOOGLE_SERVICE_ACCOUNT_JSON_BASE64=
